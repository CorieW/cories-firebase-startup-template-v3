{
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "declaration": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "outDir": "./lib",
    "sourceMap": true,
    "strict": true,
    "target": "esnext",
    "isolatedModules": true,
    "preserveConstEnums": true,
    "resolveJsonModule": true
  },
  "include": ["src/**/*"],
  "exclude": ["tests/**/*"]
}
