# ============================ Environment ============================
# NODE_ENV can be 'development', 'production', or 'test'
NODE_ENV=development
# Accepted values: debug, info, warn, error, silent
BACK_LOG_LEVEL=debug

# ============================ Firebase Project ============================
# App-specific Firebase Functions still use Firebase Admin.
PROJECT_ID=your-firebase-project-id

# ============================ Firebase Service Account ============================
# PRIVATE_KEY is the full multiline private key string, including the BEGIN/END lines, for your Firebase admin SDK.
# Be careful to keep quotes and \n for new lines.
PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nREPLACE_WITH_YOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"
# CLIENT_EMAIL is the service account's client email, e.g. 'firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com'
CLIENT_EMAIL="firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com"

# ============================ Firestore Emulator ============================
# Required in non-production environments for the backend package tests and local emulator flow.
MY_FIRESTORE_EMULATOR_HOST=127.0.0.1:8080
