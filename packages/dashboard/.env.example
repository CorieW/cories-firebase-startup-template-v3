# ============================ App URL ============================
# APP_URL is the primary origin for Better Auth callbacks and email links.
APP_URL="http://localhost:3001"
# Accepted values: debug, info, warn, error, silent
DASHBOARD_LOG_LEVEL="debug"
# Optional explicit Better Auth base URL override.
# BETTER_AUTH_URL="http://localhost:3001"

# ============================ Better Auth ============================
# BETTER_AUTH_SECRET should be a long random string in production.
BETTER_AUTH_SECRET="replace-with-a-long-random-secret"

# ============================ Google OAuth ============================
# Leave unset if you only want email/password in local development.
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ============================ Autumn Billing ============================
# AUTUMN_SECRET_KEY connects Better Auth and the billing UI to your Autumn workspace.
AUTUMN_SECRET_KEY="sk_autumn_xxxxxxxxxxxxxxxxxxxxxxxxxx"
# Optional API base URL override for self-hosted or sandbox setups.
# AUTUMN_URL="https://api.useautumn.com"
# Feature id used for organization seat entities.
AUTUMN_SEAT_FEATURE_ID="seats"

# ============================ Resend Email ============================
# Leave unset to log verification/reset/invitation emails to the server console locally.
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxx"
RESEND_FROM_EMAIL="Acme <auth@example.com>"

# ============================ Firebase Admin ============================
# Better Auth uses Firebase Admin to store auth data in Firestore.
# Leave these unset for local emulator usage or environments with application default credentials.
FIREBASE_PROJECT_ID="demo-startup-template"
# FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com"
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_REAL_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"

# Local Firestore emulator wiring.
FIRESTORE_EMULATOR_HOST="127.0.0.1:8080"
