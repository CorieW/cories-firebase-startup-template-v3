{
  "include": ["**/*.ts", "**/*.tsx"],
  "compilerOptions": {
    "target": "ES2022",
    "jsx": "react-jsx",
    "module": "ESNext",
    "baseUrl": ".",
    "paths": {
      "#/*": ["./src/*"],
      "@/*": ["./src/*"],
      "@cories-firebase-startup-template-v3/common": ["../common/src/index.ts"],
      "@cories-firebase-startup-template-v3/common/client": [
        "../common/src/client/index.ts"
      ],
      "@cories-firebase-startup-template-v3/common/auth": [
        "../common/src/auth.ts"
      ],
      "@cories-firebase-startup-template-v3/common/logging": [
        "../common/src/logging.ts"
      ]
    },
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client", "node"],

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,

    /* Linting */
    "skipLibCheck": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true
  }
}
